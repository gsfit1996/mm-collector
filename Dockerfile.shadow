FROM budtmo/docker-android-x86-11.0:latest

USER root
RUN apt-get update && apt-get install -y curl wget unzip openssh-client net-tools && \
    wget https://telegram.org/dl/android -O /telegram.apk && \
    adb install /telegram.apk && \
    rm -f /telegram.apk && \
    echo "✅ TELEGRAM PRE-INSTALLED ON EACH PHONE – ready for burner signup with SMS-Activate"

COPY entrypoint.sh /entrypoint.sh
RUN chmod +x /entrypoint.sh
ENTRYPOINT ["/entrypoint.sh"]
